{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "pyportfolios-site",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "site", "run", "dev"],
      "port": 3000
    },
    {
      "name": "static-out",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8090", "--directory", "site/out"],
      "port": 8090
    }
  ]
}
